# =========================================================
#  LLM 로컬 환경 — Git 무시 목록
#  민감 정보·대용량 파일·로그·캐시를 저장소에서 제외합니다.
# =========================================================

# ─────────────────────────────────────────────
#  설치된 환경 전체 (대용량 + 사용자별)
# ─────────────────────────────────────────────
# 14GB+ 의 모델 데이터, 컨테이너, venv 등
# 코드만 저장소에 두고 환경은 install.py 로 재생성
llm_environment/


# ─────────────────────────────────────────────
#  개인 설정 파일 (사용자별)
# ─────────────────────────────────────────────
# 마지막 워크스페이스 경로 등 개인 정보 포함
# 참고: launcher/settings 는 user_data/settings 로 향하는 정션(junction).
#       아래 규칙 + user_data 규칙이 양쪽 경로를 모두 커버한다.
launcher/settings/user_config.json
launcher/settings/*.json
!launcher/settings/.gitkeep
.webui_secret_key


# ─────────────────────────────────────────────
#  통합 사용자 데이터 (user_data/)   ★
# ─────────────────────────────────────────────
# 채팅 DB(webui.db)·설정·로그·에이전트 세션·캐시 등 전부 개인/대용량 → 저장소 제외.
# 단, 폴더 구조 설명용 README 와 빈 폴더 유지용 .gitkeep 은 추적한다.
#   - "/user_data/*" 는 바로 아래의 모든 파일/폴더(settings, logs, chat, interpreter…)를 무시
#   - "!" 예외로 최상위 README 와 .gitkeep 만 다시 포함
/user_data/*
!/user_data/.gitkeep
!/user_data/README
!/user_data/README.*


# ─────────────────────────────────────────────
#  Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경 (격리된 venv 들)
venv/
.venv/
env/
.env/

# 배포 / 빌드
dist/
build/
*.egg-info/
*.egg
.eggs/

# pip / setuptools
pip-log.txt
pip-delete-this-directory.txt
*.whl


# ─────────────────────────────────────────────
#  로그 / 임시 / 캐시
# ─────────────────────────────────────────────
*.log
logs/
*.tmp
*.cache
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/


# ─────────────────────────────────────────────
#  운영체제
# ─────────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.Trash-*


# ─────────────────────────────────────────────
#  IDE / 에디터
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/


# ─────────────────────────────────────────────
#  환경변수 / 비밀
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
secrets.yaml
credentials.json


# ─────────────────────────────────────────────
#  모델 / 데이터 파일 (대용량)
# ─────────────────────────────────────────────
# 어디에 있든 GGUF/safetensors 파일은 저장소에 안 들어감
*.gguf
*.safetensors
*.bin
*.pth
*.pt
*.ckpt
*.h5
*.onnx

# 모델 메타
manifests/
blobs/


# ─────────────────────────────────────────────
#  Docker (이미지·컨테이너는 시스템에 저장됨, 코드만 저장)
# ─────────────────────────────────────────────
# Dockerfile 자체는 저장 (재현 가능성)
# 빌드 컨텍스트 산출물은 제외
.docker/


# ─────────────────────────────────────────────
#  사용자 작업 데이터
# ─────────────────────────────────────────────
# 에이전트가 만든 파일 / 사용자 업로드
agent/workspace/*
!agent/workspace/.gitkeep
!agent/workspace/README.txt

# Open WebUI 채팅 기록·업로드 파일 (레거시 경로 — 현재는 user_data/chat 사용)
chat_ui/data/
*.db
*.sqlite
*.sqlite3